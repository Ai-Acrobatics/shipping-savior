# Supabase PostgreSQL connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
# Use the "Transaction pooler" connection string from Supabase Dashboard > Settings > Database
DATABASE_URL=

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# OAuth — Google
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
# Create app at https://github.com/settings/developers
# Authorization callback URL: ${AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend (transactional email — password reset + email verification)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=
# Sender address for outbound auth emails. Use onboarding@resend.dev when no
# custom domain has been verified in Resend; switch to noreply@<verified-domain>
# once DNS is set up.
EMAIL_FROM=onboarding@resend.dev

# Public base URL used to build absolute links inside emails (reset-password,
# verify-email). Falls back to AUTH_URL when not set.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email-verification gate. When `true`, unverified credentials users are
# bounced from /platform/* to /verify-email by middleware. Default `false` so
# we don't break existing accounts.
REQUIRE_EMAIL_VERIFICATION=false

# Anthropic API (for AI chatbot)
ANTHROPIC_API_KEY=
