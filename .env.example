# Supabase PostgreSQL connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
# Use the "Transaction pooler" connection string from Supabase Dashboard > Settings > Database
DATABASE_URL=

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Anthropic API (for AI chatbot)
ANTHROPIC_API_KEY=

# Stripe billing (AI-8777)
# Server-side secret key (sk_test_... or sk_live_...) — from Stripe dashboard > Developers > API keys
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) — from Stripe dashboard > Developers > Webhooks > [endpoint] > Signing secret
STRIPE_WEBHOOK_SECRET=
# Browser-side publishable key (pk_test_... or pk_live_...) — safe to expose
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs for each paid plan — create products in Stripe dashboard, then paste the price IDs here
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
