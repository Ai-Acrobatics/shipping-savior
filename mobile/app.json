{
  "expo": {
    "name": "Shipping Savior",
    "slug": "shipping-savior",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shippingsavior",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f172a",
    "ios": {
      "bundleIdentifier": "com.shippingsavior.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Shipping Savior uses the camera to scan Bills of Lading so shipment data can be extracted automatically.",
        "NSPhotoLibraryUsageDescription": "Shipping Savior lets you pick a Bill of Lading photo or PDF scan from your library for data extraction."
      }
    },
    "android": {
      "package": "com.shippingsavior.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f172a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0ea5e9"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
